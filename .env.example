# OAuth Client credentials
APP_ID=your_app_id_here
SECRET=your_client_secret_here

# Token endpoint (POST) — used for both client_credentials and code exchange
ENDPOINT=https://openapi.wps.cn/oauth2/token

# Pre-built authorization URL for authorization_code flow
# Must include redirect_uri — it will be parsed automatically to start the local callback server
AUTH_URL=https://openapi.wps.cn/oauth2/auth?response_type=code&client_id=${APP_ID}&redirect_uri=http%3A%2F%2Flocalhost%3A18000%2Fkoa-callback

# Base URL for API calls after obtaining the access token
API_BASE_URL=https://openapi.wps.cn/v7

# Optional: space-separated scopes for client_credentials flow
SCOPES=kso.user_base.read,kso.drive.readwrite,kso.file.readwrite,kso.airsheet.readwrite,kso.airpage.readwrite
